# Copy this file to .env and fill in your values.
# On RunPod, set these as Environment Variables in the pod/template settings.

# ── Required ──
# HuggingFace token (needed to download Qwen2.5-7B-Instruct)
HUGGINGFACE_TOKEN=hf_your_token_here

# ── Optional — Training hyperparameters ──
BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
OUTPUT_DIR=/workspace/taoist_finetuned
DATA_DIR=/workspace/taoist_data
EPOCHS=3
BATCH_SIZE=2
GRAD_ACCUM=4
LORA_R=16

# Set to "true" to skip web scraping and reuse existing local data
SKIP_SCRAPING=false
